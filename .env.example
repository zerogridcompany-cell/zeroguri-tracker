# ───────── Supabase ─────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key   # Edge Functions only. NEVER ship to client.

# ───────── Token encryption ─────────
# 32-byte key, base64. Production: fetch from KMS at boot, do not store in plaintext env.
#   openssl rand -base64 32
TOKEN_ENC_KEY=

# ───────── Tracking engine ─────────
TRACKER_SANDBOX=true          # true = providers return deterministic simulated growth (no creds needed)
TRACKING_BATCH_LIMIT=500      # max active videos claimed per tick
DEFAULT_CAP=500000
DEFAULT_UNIT_PRICE=0.1        # ¥ per view（= ¥100 / 1,000再生）

# ═════════ 無審査ルート（App Review 不要）═════════
# YouTube: 公開統計は API キーのみ（OAuth 不要・審査不要）。Cloud で YouTube Data API v3 を有効化し API キー発行。
YOUTUBE_API_KEY=

# Instagram: Business Discovery を Development Mode で使う（審査不要）。
#   自分の IG プロアカ(=IG_BUSINESS_USER_ID) + FBページ + 長期トークン(IG_BUSINESS_DISCOVERY_TOKEN)。
#   これで任意の公開プロ(Business/Creator)アカの Reels view_count を読める。
IG_BUSINESS_USER_ID=
IG_BUSINESS_DISCOVERY_TOKEN=

# TikTok: Login Kit + Display API を「Sandbox」モードで（審査不要・テストアカウント数制限・SELF_ONLY）。
#   本人 OAuth で連携。下の TIKTOK_* を Sandbox アプリの値にする。
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_OAUTH_REDIRECT=http://127.0.0.1:54321/functions/v1/oauth-callback

# ───────── OAuth: YouTube/Instagram（無審査ルートでは未使用・将来の上位互換用）─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://127.0.0.1:54321/functions/v1/oauth-callback
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_OAUTH_REDIRECT=http://127.0.0.1:54321/functions/v1/oauth-callback

# Where to send the user back after a successful link
APP_POST_OAUTH_REDIRECT=http://localhost:3000/dashboard

# ───────── Web (Next.js) ─────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
NEXT_PUBLIC_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1
